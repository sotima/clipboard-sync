# Copy this file to .env and set a strong password
CLIPBOARD_PASSWORD=enter-a-strong-password-here

# Set to true when the service is accessible via HTTPS (Pangolin/LetsEncrypt)
# Set to false for local testing without HTTPS only
SECURE_COOKIES=true

# Maximum clipboard content size in KB (default: 512)
MAX_CONTENT_KB=512

# Maximum file upload size in MB (default: 10)
MAX_FILE_MB=10

# Default UI language: de or en (default: de)
DEFAULT_LANG=de
