# Kopiere diese Datei nach .env und setze ein sicheres Passwort
CLIPBOARD_PASSWORD=hier-ein-sicheres-passwort-eintragen

# Auf true lassen wenn der Dienst ueber HTTPS erreichbar ist (Pangolin/LetsEncrypt)
# Nur auf false setzen fuer lokale Tests ohne HTTPS
SECURE_COOKIES=true

# Maximale Groesse des Clipboard-Inhalts in KB (Standard: 512)
MAX_CONTENT_KB=512

# Standardsprache der Oberfläche: de oder en (Standard: de)
DEFAULT_LANG=de
